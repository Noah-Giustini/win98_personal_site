# API auth settings
API_KEY=replace_me
API_KEY_NAME=access_token

# Nebula API bind settings
SERVER_IP=0.0.0.0
SERVER_PORT=8000

# Zomboid systemd integration
ZOMBOID_SERVICE_NAME=zomboid.service
SYSTEMCTL_BIN=/bin/systemctl
SYSTEMCTL_USE_SUDO=false

# Player parsing log candidates (comma separated)
ZOMBOID_LOG_FILE=/home/zomboid/Zomboid/server-console.txt
ZOMBOID_LOG_CANDIDATES=/home/zomboid/Zomboid/server-console.txt,/home/zomboid/Zomboid/Logs/server-console.txt,/home/zomboid/Zomboid/Logs/coop-console.txt

# Optional command for /zomboid/mods/update endpoint
ZOMBOID_MOD_UPDATE_COMMAND=/opt/pzserver/scripts/zomboid_sync_collection.py --collection-id 3178279542

# Script used by /system/update endpoint
NEBULA_DEPLOY_SCRIPT=/opt/nebula-api/deploy_nebula.sh
